{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    // Configuration TypeORM
    "experimentalDecorators": true, 
    "emitDecoratorMetadata": true,
    // Configuration Bun
    "module": "esnext",
    "moduleResolution": "bundler",
    
    // Ajouts recommandés : 
    "target": "ESNext",     // Pour garder le code moderne
    "types": ["bun-types"]  // Pour reconnaître les fonctions Bun
  }
}