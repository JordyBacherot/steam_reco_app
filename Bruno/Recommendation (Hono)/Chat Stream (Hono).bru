meta {
  name: Chat Stream (Hono)
  type: http
  seq: 4
}

post {
  url: {{host}}/recommendations/chat
  body: json
  auth: bearer
}


auth:bearer {
  token: {{token}}
}

body:json {
  {
    "session_id": "641cdde5-ae28-432c-a687-812b628052a3",
    "message": "Autre chose ? ",
    "history": [],
    "temperature": 0.2
  }
}

assert {
  res.status: eq 200
}
