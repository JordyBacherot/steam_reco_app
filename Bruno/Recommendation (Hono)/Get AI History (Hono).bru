meta {
  name: Get AI History (Hono)
  type: http
  seq: 5
}

get {
  url: {{host}}/recommendations/history/ai?limit=10
  body: none
  auth: bearer
}

params:query {
  limit: 10
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.history_ai: isArray
  res.body.count: isNumber
}
