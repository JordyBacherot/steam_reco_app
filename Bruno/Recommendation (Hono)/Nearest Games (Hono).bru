meta {
  name: Nearest Games (Hono)
  type: http
  seq: 3
}

get {
  url: {{host}}/recommendations/nearest_games/Skyrim?limit=5
  body: none
  auth: bearer
}

params:query {
  limit: 5
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.query: isString
  res.body.found: isBoolean
  res.body.nearest_games: isArray
}
