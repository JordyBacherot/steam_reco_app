meta {
  name: AddGameToLibrary
  type: http
  seq: 1
}

post {
  url: {{host}}/users/{{userId}}/games
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id_game": 220,
    "nb_hours": 105.5
  }
}

assert {
  res.status: in [200, 201]
  res.body.success: eq true
  res.body.message: isString
  res.body.data: isJson
}
