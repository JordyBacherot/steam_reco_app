meta {
  name: CreateSteamUser
  type: http
  seq: 1
}

post {
  url: {{host}}/steam_users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id_steam": "76561198012345679",
    "id_user": {{userId}},
    "username": "SteamBrunoUser",
    "level": 42
  }
}

assert {
  res.status: eq 201
}
