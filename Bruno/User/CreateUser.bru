meta {
  name: CreateUser
  type: http
  seq: 1
}

post {
  url: {{host}}/users
  body: json
  auth: inherit
}

body:json {
  {
    "email": "bruno_test@example.com",
    "username": "BrunoUser",
    "password": "password123",
    "have_steamid": false
  }
}

vars:post-response {
  new_userId: res.body.id_user
}

assert {
  res.status: eq 201
}
