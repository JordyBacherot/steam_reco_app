meta {
  name: SignUp
  type: http
  seq: 1
}

post {
  url: {{host}}/auth/signup
  body: json
  auth: inherit
}

body:json {
  {
    "email": "anotheruser@example.com",
    "username": "AnotherUser",
    "password": "password123"
  }
}

vars:post-response {
  token: res.body.token
  refreshToken: res.body.refreshToken
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

settings {
  encodeUrl: true
  timeout: 0
}
