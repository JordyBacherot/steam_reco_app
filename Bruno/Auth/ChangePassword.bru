meta {
  name: ChangePassword
  type: http
  seq: 5
}

post {
  url: {{host}}/auth/password/change
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "oldPassword": "password123",
    "newPassword": "newpassword456"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

settings {
  encodeUrl: true
  timeout: 0
}
